# ── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...                  # from @BotFather
ADMIN_CHAT_ID=672890533                 # Hiep's Telegram user_id

# ── Google Sheets ───────────────────────────────────────────
GOOGLE_SHEET_ID=...                     # spreadsheet ID from URL
GOOGLE_SERVICE_ACCOUNT_FILE=/root/.hermes/mcm-vendor-sa.json  # absolute path

# ── EspoCRM Docker ─────────────────────────────────────────
ESPOCRM_URL=http://103.97.126.28:8080   # public URL (not localhost)
ESPOCRM_API_USER=admin
ESPOCRM_API_KEY=...                     # Admin > API Keys in EspoCRM UI
MYSQL_ROOT_PASSWORD=mcm_root_2026
MYSQL_PASSWORD=mcm_espo_2026
ESPO_USER=admin
ESPO_PASS=mcm_admin_2026

# ── Hermes / Webhook security ──────────────────────────────
HERMES_WEBHOOK_SECRET=...              # optional HMAC secret for /webhook/capture
ESPO_WEBHOOK_SECRET=...               # optional HMAC secret for Agent 4 routes

# ── Agent 4 — Affiliate deep links ─────────────────────────
